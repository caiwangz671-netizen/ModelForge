{
  "name": "modelforge-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "ModelForge desktop wrapper",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "package:mac": "electron-packager . ModelForge --platform=darwin --arch=arm64 --out ../release --overwrite --prune=true --app-bundle-id com.modelforge.desktop --ignore=\"^/release/\""
  },
  "devDependencies": {
    "@electron/packager": "^18.4.4",
    "electron": "^35.0.3"
  }
}
