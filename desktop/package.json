{
  "name": "modelforge-desktop",
  "version": "1.1.1",
  "private": true,
  "author": "ModelForge Contributors",
  "description": "ModelForge desktop wrapper",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "generate:icon": "python ..\\scripts\\generate-desktop-icons.py",
    "package:mac": "electron-packager . ModelForge --platform=darwin --arch=arm64 --out ../release --overwrite --prune=true --app-bundle-id com.modelforge.desktop --ignore=\"^/release/\"",
    "package:win": "npx electron-builder@26.0.12 --win --x64 --publish never",
    "package:win:portable": "npx electron-builder@26.0.12 --win portable --x64 --publish never",
    "package:win:installer": "npx electron-builder@26.0.12 --win nsis --x64 --publish never"
  },
  "build": {
    "appId": "com.modelforge.desktop",
    "productName": "ModelForge",
    "icon": "icon.png",
    "asar": true,
    "directories": {
      "output": "../release"
    },
    "files": [
      "**/*",
      "!frontend-dist",
      "!frontend-dist/**",
      "!backend-bin",
      "!backend-bin/**"
    ],
    "extraResources": [
      {
        "from": "frontend-dist",
        "to": "app/frontend-dist"
      },
      {
        "from": "backend-bin",
        "to": "app/backend-bin"
      }
    ],
    "win": {
      "icon": "icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "icon": "icon.icns"
    },
    "nsis": {
      "artifactName": "${productName}-${version}-nsis.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-${arch}-portable.${ext}"
    }
  },
  "devDependencies": {
    "@electron/packager": "^18.4.4",
    "electron": "^35.0.3"
  }
}
